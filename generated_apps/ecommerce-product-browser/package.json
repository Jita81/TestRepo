{
  "name": "ecommerce-product-browser",
  "version": "1.0.0",
  "description": "E-Commerce Product Browsing and Search System",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev:backend": "nodemon backend/src/server.js",
    "dev:frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:all": "npm run test:backend && npm run test:frontend && npm run test:e2e",
    "test:watch": "jest --watch",
    "test:backend": "jest backend/ --coverage --testTimeout=10000",
    "test:backend:cart": "jest backend/tests/services/CartService.test.js backend/tests/integration/cart.api.test.js --verbose",
    "test:frontend": "cd frontend && npm test -- --watchAll=false --coverage",
    "test:frontend:cart": "cd frontend && npm test -- --testPathPattern=cart --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:cart": "playwright test cart.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint backend/ frontend/src/",
    "lint:fix": "eslint backend/ frontend/src/ --fix",
    "db:seed": "node backend/src/scripts/seed.js",
    "db:reset": "npm run db:seed"
  },
  "keywords": [
    "ecommerce",
    "product-search",
    "elasticsearch",
    "react",
    "redux",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@elastic/elasticsearch": "^8.10.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "winston": "^3.11.0",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}