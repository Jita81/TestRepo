# SQLite database path (default: data/context_platform.db)
# CONTEXT_DB_PATH=data/context_platform.db

# Optional: OpenAI for meeting extraction (else pattern stub)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Manufacturing stub writes markdown here
# MANUFACTURING_OUTPUT_DIR=data/manufacturing_outputs

# Default actor for API actions (overridable per request with X-Context-Actor)
# CONTEXT_ACTOR=local-dev

# Default project id when no X-Context-Project header / context_project_id cookie
# CONTEXT_PROJECT_ID=prj_default

# D8: allow sprint commits without an approved context package (dev/admin only)
# CONTEXT_ALLOW_UNAPPROVED_SPRINT_COMMIT=1

# If set, all /api/* requests must send X-Context-API-Key or Authorization: Bearer (dashboard /context is not gated)
# CONTEXT_API_KEY=

HOST=0.0.0.0
PORT=8000
