# Server Configuration
NODE_ENV=development
PORT=3000

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Database Configuration (when you add a database)
# DATABASE_URL=mongodb://localhost:27017/nodejs-starter
# DATABASE_URL=postgresql://user:password@localhost:5432/nodejs_starter
# DATABASE_URL=mysql://user:password@localhost:3306/nodejs_starter

# Redis Configuration (for session storage, caching)
# REDIS_URL=redis://localhost:6379

# Email Configuration (for password reset, notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL=noreply@yourapp.com

# AWS Configuration (for file uploads, S3)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Google OAuth (for social login)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (for social login)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# API Keys (for external services)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# SENDGRID_API_KEY=SG...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...

# Development Tools
# ENABLE_SWAGGER=true
# ENABLE_GRAPHQL_PLAYGROUND=true

# Monitoring and Analytics
# SENTRY_DSN=https://your-sentry-dsn
# GOOGLE_ANALYTICS_ID=UA-...

# Feature Flags
# ENABLE_REGISTRATION=true
# ENABLE_EMAIL_VERIFICATION=false
# ENABLE_PASSWORD_RESET=true
# ENABLE_TWO_FACTOR_AUTH=false

# Cache Configuration
# CACHE_TTL=3600
# ENABLE_CACHE=true

# Webhook URLs
# WEBHOOK_SECRET=your-webhook-secret
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...