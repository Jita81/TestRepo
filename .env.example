# Operator / deploy guide: docs/deploy-runbook.md  (README → Deployment)
#
# SQLite database path (default: data/context_platform.db)
# CONTEXT_DB_PATH=data/context_platform.db

# Optional: OpenAI for meeting extraction (else pattern stub)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Manufacturing: outputs + MANUFACTURING.md per request
# MANUFACTURING_OUTPUT_DIR=data/manufacturing_outputs
#
# Phase 3 — optional git adapter (unset = lightweight stub)
# MANUFACTURING_GIT_URL=https://github.com/octocat/Hello-World.git
# MANUFACTURING_GIT_REF=main
# MANUFACTURING_GIT_DEPTH=1
# MANUFACTURING_PATCH_FILE=/path/to/changes.patch   # optional; git apply after clone
# MANUFACTURING_RUN_CMD=pytest -q                    # optional; sh -c from repo root
# MANUFACTURING_TIMEOUT_SEC=600

# Default actor for API actions (overridable per request with X-Context-Actor)
# CONTEXT_ACTOR=local-dev

# Default project id when no X-Context-Project header / context_project_id cookie
# CONTEXT_PROJECT_ID=prj_default

# D8: allow sprint commits without an approved context package (dev/admin only)
# CONTEXT_ALLOW_UNAPPROVED_SPRINT_COMMIT=1

# If set, all /api/* requests must send X-Context-API-Key or Authorization: Bearer
# (Dashboard /context is gated separately when CONTEXT_DASHBOARD_PASSWORD is set.)
# Webhooks under /api/context/webhooks/ are exempt; use CONTEXT_SCM_WEBHOOK_SECRET for HMAC.
# CONTEXT_API_KEY=

# GitHub SCM webhook HMAC (optional; if unset, signatures are not required — dev only)
# CONTEXT_SCM_WEBHOOK_SECRET=

# --- Dashboard login (Phase 2) ---
# If CONTEXT_DASHBOARD_PASSWORD is set, /context/* requires a signed session cookie.
# CONTEXT_SESSION_SECRET must be at least 32 characters (e.g. openssl rand -hex 32).
# CONTEXT_DASHBOARD_PASSWORD=
# CONTEXT_SESSION_SECRET=
# CONTEXT_DASHBOARD_USER=admin
# CONTEXT_SESSION_HTTPS_ONLY=1   # set behind HTTPS in production

HOST=0.0.0.0
PORT=8000
