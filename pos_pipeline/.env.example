# API Settings
API_KEY=your-secure-api-key-here
API_TITLE=POS Display Pipeline
API_VERSION=1.0.0

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=False

# RabbitMQ Settings
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Storage Settings
STORAGE_PATH=/workspace/pos_pipeline/storage
MAX_STORAGE_SIZE_MB=1000

# Processing Limits
MAX_TEXT_LENGTH=1024
MAX_CONCURRENT_PROCESSES=5
MAX_VIDEO_SIZE_MB=100
MAX_MODEL_SIZE_MB=50

# Video Settings
VIDEO_FORMAT=mp4
MIN_VIDEO_DURATION=30
VIDEO_FPS=24

# Model Settings
MODEL_FORMAT=stl
MESH_QUALITY=medium

# Timeout Settings (seconds)
TEXT_PROCESSING_TIMEOUT=60
VIDEO_GENERATION_TIMEOUT=300
MODEL_CONVERSION_TIMEOUT=180

# Logging
LOG_LEVEL=INFO
LOG_FILE=/workspace/pos_pipeline/logs/pipeline.log