{
  "name": "todo-list-app",
  "version": "1.0.0",
  "description": "A full-stack todo list application with add, complete, and delete functionality",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "db:migrate": "node backend/database/migrate.js",
    "db:seed": "node backend/database/seed.js"
  },
  "keywords": [
    "todo",
    "fullstack",
    "rest-api",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/database/migrate.js",
      "!backend/database/seed.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}