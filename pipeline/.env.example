# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_TIMEOUT=30
# API_KEY=your_secret_api_key_here

# Queue Settings
QUEUE_HOST=localhost
QUEUE_PORT=5672
QUEUE_USERNAME=guest
QUEUE_PASSWORD=guest
QUEUE_RETRY_COUNT=3

# Video Generation Settings
VIDEO_MODEL_PATH=models/video_gen
VIDEO_FRAME_RATE=30
VIDEO_DURATION=30
VIDEO_WIDTH=512
VIDEO_HEIGHT=512

# Model Conversion Settings
POINT_CLOUD_DENSITY=1000
MESH_QUALITY=medium

# Storage Settings
STORAGE_BASE_PATH=storage
VIDEO_STORAGE_PATH=storage/videos
MODEL_STORAGE_PATH=storage/models
TEMP_STORAGE_PATH=storage/temp
MAX_STORAGE_MB=10240

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
JSON_LOGS=true

# Performance Settings
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_SECONDS=600
CLEANUP_INTERVAL_SECONDS=3600